# Variables de entorno — Plantilla SGPI
# Copia este archivo como .env y rellena los valores reales
# ⚠️  NUNCA subas el archivo .env a Git

# ── Supabase ──────────────────────────────────────────────────
SUPABASE_URL=https://TU-PROYECTO.supabase.co

# Clave pública (Settings → API → anon public)
SUPABASE_ANON_KEY=eyJ...

# Clave secreta de servicio (Settings → API → service_role secret)
# ⚠️ Solo para uso en backend — nunca exponerla al frontend
SUPABASE_SERVICE_KEY=eyJ...

# ── PostgreSQL directo (para ejecutar migraciones SQL) ────────
# Settings → Database → Connection string → URI (Transaction pooler)
DATABASE_URL=postgresql://postgres.TU-REF:[PASSWORD]@aws-X.pooler.supabase.com:6543/postgres

# ── Servidor ──────────────────────────────────────────────────
PORT=3000

